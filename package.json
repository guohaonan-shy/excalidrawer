{
  "name": "excalidrawer",
  "version": "0.5.0",
  "description": "Code-first Excalidraw diagram generation with SVG/PNG export and CLI",
  "type": "module",
  "main": "./src/index.mjs",
  "bin": {
    "excalidrawer": "./src/cli.mjs"
  },
  "exports": {
    ".": "./src/index.mjs",
    "./templates": "./src/templates/index.mjs"
  },
  "scripts": {
    "test": "node examples/basic.mjs"
  },
  "keywords": [
    "excalidraw",
    "diagram",
    "flowchart",
    "svg",
    "png",
    "architecture",
    "code-first"
  ],
  "author": "guohaonan-shy",
  "license": "MIT",
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "wawoff2": "^2.0.1"
  }
}
